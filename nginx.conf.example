# Nginx reverse proxy configuration for Pete DealMachine Cleaner
#
# Installation:
#   1. Copy to /etc/nginx/sites-available/pete-dm-clean
#   2. Update server_name and paths
#   3. Create symlink: ln -s /etc/nginx/sites-available/pete-dm-clean /etc/nginx/sites-enabled/
#   4. Test: nginx -t
#   5. Reload: systemctl reload nginx
#
# SSL/TLS:
#   Consider using Let's Encrypt with certbot for automatic SSL certificates
#   certbot --nginx -d yourdomain.com

upstream pete_backend {
    # Application server
    server 127.0.0.1:8765;

    # For load balancing, add more servers:
    # server 127.0.0.1:8766;
    # server 127.0.0.1:8767;

    # Health check (requires nginx-plus or custom module)
    # health_check interval=10s fails=3 passes=2;
}

server {
    listen 80;
    listen [::]:80;
    server_name pete.yourdomain.com;

    # Redirect HTTP to HTTPS (uncomment when SSL is configured)
    # return 301 https://$server_name$request_uri;

    # Client max body size (for file uploads)
    client_max_body_size 100M;

    # Timeouts
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # Logging
    access_log /var/log/nginx/pete-dm-clean-access.log;
    error_log /var/log/nginx/pete-dm-clean-error.log warn;

    # Static files (if serving from nginx)
    location /static/ {
        alias /opt/pete-dm-clean/static/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Health check endpoint (no auth required)
    location /health {
        proxy_pass http://pete_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        access_log off;
    }

    # Application routes
    location / {
        proxy_pass http://pete_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support (if needed in future)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Disable buffering for better performance with large files
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}

