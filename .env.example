# Pete DealMachine Cleaner - Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# Application Settings
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Server port
PORT=8765

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# File Storage
# ============================================================================

# Directory for uploads, runs, diagrams (default: uploads)
UPLOADS_DIR=uploads

# ============================================================================
# Database (Optional Metadata Storage)
# ============================================================================

# Enable database (0 = disabled, 1 = enabled)
DB_ENABLED=0

# SQLite: Use file path
DB_PATH=uploads/metadata.db

# PostgreSQL: Use connection URL (overrides DB_PATH if set)
# DB_URL=postgresql://pete:password@localhost:5432/pete_dm_clean

# ============================================================================
# Build Defaults (Override via CLI flags)
# ============================================================================

# Export filename prefix
# EXPORT_PREFIX=PETE.DM.FERNANDO.CLEAN

# Date format for export filenames
# EXPORT_DATE_FORMAT=%m.%d.%y

# Desktop copy enabled by default (0 = disabled, 1 = enabled)
# DESKTOP_COPY=1

# ============================================================================
# Development Settings
# ============================================================================

# Enable auto-reload in development
RELOAD=true

# ============================================================================
# Production Settings (uncomment for production)
# ============================================================================

# ENVIRONMENT=production
# LOG_LEVEL=WARNING
# RELOAD=false
# DB_ENABLED=1
# DB_URL=postgresql://pete:${DB_PASSWORD}@db:5432/pete_dm_clean
